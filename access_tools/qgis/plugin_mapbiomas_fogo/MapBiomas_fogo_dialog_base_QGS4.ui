    <widget class="QLabel" name="Descriotion_download">
     <property name="geometry">
      <rect>
       <x>10</x>
       <y>58</y>
       <width>491</width>
       <height>111</height>
      </rect>
     </property>
     <property name="text">
      <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;O plugin utiliza transmissão via streaming direto do &lt;span style=&quot; font-style:italic;&quot;&gt;Google Cloud Storage&lt;/span&gt; para renderizar instantaneamente os dados na área de visualização (canvas) do QGIS.&lt;/p&gt;&lt;p&gt;Você pode realizar análises espaciais e geoprocessamentos normalmente como interseções, recortes e filtros. Os resultados gerados podem ser salvos diretamente na memória temporária do sistema ou exportados para um diretório local de sua preferência.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
     </property>
     <property name="alignment">
      <set>Qt::AlignmentFlag::AlignJustify|Qt::AlignmentFlag::AlignVCenter</set>
     </property>
     <property name="wordWrap">
      <bool>true</bool>
     </property>
    </widget>
    <widget class="QLabel" name="Descriotion_download_2">
     <property name="geometry">
      <rect>
       <x>10</x>
       <y>168</y>
       <width>631</width>
       <height>131</height>
      </rect>
     </property>
     <property name="text">
      <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Como funciona o download:&lt;/span&gt;&lt;/p&gt;&lt;ol style=&quot;margin-top: 0px; margin-bottom: 0px; margin-left: 0px; margin-right: 0px; -qt-list-indent: 1;&quot;&gt;&lt;li style=&quot; margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Seleção:&lt;/span&gt; Escolha os anos da Coleção N que deseja analisar.&lt;/li&gt;&lt;li style=&quot; margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Streaming:&lt;/span&gt; O plugin busca o arquivo FGD público e renderiza os vetores dinamicamente no canvas.&lt;/li&gt;&lt;li style=&quot; margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Análise:&lt;/span&gt; Execute ferramentas de geoprocessamento padrão do QGIS normalmente.&lt;/li&gt;&lt;li style=&quot; margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Salvamento:&lt;/span&gt; Exporte o resultado para seu computador ou trabalhe em memória interna.&lt;/li&gt;&lt;/ol&gt;&lt;/body&gt;&lt;/html&gt;</string>
     </property>
     <property name="alignment">
      <set>Qt::AlignmentFlag::AlignJustify|Qt::AlignmentFlag::AlignVCenter</set>
     </property>
     <property name="wordWrap">
      <bool>true</bool>
     </property>
    </widget>
